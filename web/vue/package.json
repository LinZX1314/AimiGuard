    "echarts": "^5.6.0",
    "lucide-vue-next": "^0.577.0",
    "marked": "^15.0.12",
    "pinia": "^2.3.1",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "topojson-client": "^3.1.0",
