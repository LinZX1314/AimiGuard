{
  "name": "aimiguard-vue",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "clean": "node -e \"const fs=require('fs');const p='../static/vue-dist';try{fs.rmSync(p,{recursive:true,force:true});console.log('Cleaned: '+p);}catch(e){console.log('Skip clean:',e.message);}\"",
    "build": "pnpm clean && vue-tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "chart.js": "^4.4.7",
    "echarts": "^5.6.0",
    "marked": "^15.0.12",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.5.0",
    "vuetify": "^3.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "sass": "^1.85.1",
    "typescript": "^5.7.3",
    "vite": "^6.2.1",
    "vite-plugin-vuetify": "^2.1.0",
    "vue-tsc": "^2.2.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher", "esbuild", "vue-demi"]
  }
}
