# ============================================
# AimiGuard 生产环境配置
# ============================================

# 应用配置
APP_ENV=production
APP_VERSION=1.0.0
DEBUG=false

# 数据库
DATABASE_URL=sqlite:////data/aimiguard.db

# 安全配置
JWT_SECRET=<生产环境强密钥-至少32字符-请替换>
JWT_EXPIRE_MINUTES=60
ENCRYPTION_KEY=<AES加密主密钥-32字节base64-请替换>

# AI 模型
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:14b
LLM_TIMEOUT_SECONDS=60
TTS_PROVIDER=coqui
TTS_MODEL_PATH=/models/tts

# MCP 配置
MCP_MODE=stdio
MCP_SERVER_NAME=switch-controller

# 外部集成
FIREWALL_API_URL=https://firewall.example.com/api
FIREWALL_API_KEY=<防火墙API密钥-请替换>
FIREWALL_SIGN_SECRET=<防火墙签名密钥-请替换>

# 审计与日志
AUDIT_ENABLED=true
LOG_LEVEL=INFO
LOG_FILE=/var/log/aimiguard/app.log

# 性能配置
MAX_WORKERS=4
TASK_QUEUE_SIZE=100
SCAN_CONCURRENCY=5

# IP 白名单（逗号分隔，留空则不启用）
IP_WHITELIST=
IP_WHITELIST_ENABLED=false

# 伪装配置
DECOY_ENABLED=false
HIDE_TECH_STACK=true
FAKE_SERVER_HEADER=Apache/2.4.41
HONEYPOT_ENABLED=false

# 速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_LOGIN_PER_MINUTE=5
LOGIN_RATE_LIMIT=5

# 访问控制
REQUIRE_CLIENT_CERT=false
VPN_ONLY_MODE=false
PORT_KNOCKING_ENABLED=false
ADMIN_PANEL_ALLOWED_IPS=127.0.0.1,::1

# 审计增强
LOG_BLOCKED_ACCESS=true
AUTO_BLACKLIST_THRESHOLD=10

# SPA 单包授权
SPA_SECRET=<SPA授权密钥-至少32字符-请替换>
SPA_TOKEN_TTL=300
