# Database
DATABASE_URL=sqlite:///./aimiguard.db

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=60

# LLM Configuration
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama2
# LLM_API_KEY=
# LLM_TIMEOUT_SECONDS=30

# MCP Configuration
MCP_MODE=stdio
MCP_SERVER_NAME=switch-controller
# MCP_SERVER_URL=
# MCP_STDIO_COMMAND=
# MCP_TIMEOUT=30

# Scanner Configuration
SCANNER_MAX_CONCURRENT=3
# SCAN_OUTPUT_DIR=scan_outputs

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Push Notification (推送通道)
# PUSH_SANDBOX_MODE=0
# PUSH_TIMEOUT_SECONDS=10
# PUSH_SMTP_HOST=
# PUSH_SMTP_PORT=587
# PUSH_SMTP_USER=
# PUSH_SMTP_PASSWORD=
# PUSH_SMTP_TLS=1
# PUSH_SMTP_FROM=

# TTS (语音合成)
# TTS_PROVIDER=local
# TTS_ENDPOINT=
# TTS_BASE_URL=
# TTS_MODEL=local-tts-v1
# TTS_TIMEOUT_SECONDS=30
# TTS_API_KEY=
# TTS_SANDBOX_MODE=0

# STT (语音识别)
# STT_PROVIDER=local
# STT_ENDPOINT=
# STT_BASE_URL=
# STT_TIMEOUT_SECONDS=10
# STT_API_KEY=

# SPA (单包授权)
# SPA_SECRET=
# SPA_TOKEN_TTL=300

# Credential Encryption (凭据加密)
# CREDENTIAL_KEY_V1=          # AES-256 base64url, 留空则自动生成
# CREDENTIAL_KEY_V2=          # 密钥轮换时配置

# Firewall Integration (防火墙)
# FIREWALL_API_URL=
# FIREWALL_SIGN_SECRET=

# Security (安全)
# IP_WHITELIST=                # 逗号分隔的IP白名单
# DECOY_ENABLED=0
# DEFENSE_RUNTIME_WORKFLOW_KEY=
# ROLLBACK_CANDIDATE_LIMIT=10