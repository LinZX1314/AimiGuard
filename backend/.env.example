# Database
DATABASE_URL=sqlite:///./aimiguard.db

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=60

# LLM Configuration
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama2

# MCP Configuration
MCP_MODE=stdio
MCP_SERVER_NAME=switch-controller

# Scanner Configuration
SCANNER_MAX_CONCURRENT=3

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Push Notification (推送通道)
# PUSH_SANDBOX_MODE=0
# PUSH_TIMEOUT_SECONDS=10
# PUSH_SMTP_HOST=
# PUSH_SMTP_PORT=587
# PUSH_SMTP_USER=
# PUSH_SMTP_PASSWORD=
# PUSH_SMTP_TLS=1
# PUSH_SMTP_FROM=

# TTS (语音合成)
# TTS_PROVIDER=local
# TTS_ENDPOINT=
# TTS_MODEL=local-tts-v1
# TTS_TIMEOUT_SECONDS=30
# TTS_API_KEY=
# TTS_SANDBOX_MODE=0

# STT (语音识别)
# STT_PROVIDER=local
# STT_ENDPOINT=
# STT_TIMEOUT_SECONDS=10
# STT_API_KEY=

# Firewall Integration (防火墙)
# FIREWALL_API_URL=