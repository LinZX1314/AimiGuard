# ============================================================
# Aimiguan 后端环境配置
# 复制此文件为 .env 并根据需要修改默认值
# ============================================================

# Database (SQLite 数据库路径)
DATABASE_URL=sqlite:///./aimiguard.db

# JWT Authentication (生产环境请使用强随机密钥)
# 启动脚本会自动生成随机密钥，如需手动设置请修改下方值
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=60

# ============================================================
# LLM 大语言模型配置 (AI 功能)
# ============================================================
# 支持: ollama, openai, anthropic, azure_openai
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama2
# LLM_API_KEY=  # OpenAI/Anthropic 等需要填写
# LLM_TIMEOUT_SECONDS=30

# ============================================================
# MCP (Model Context Protocol) 配置
# ============================================================
MCP_MODE=stdio
MCP_SERVER_NAME=switch-controller
# MCP_SERVER_URL=  # HTTP 模式时使用
# MCP_STDIO_COMMAND=  # STDIO 模式时使用
# MCP_TIMEOUT=30

# ============================================================
# 扫描器配置
# ============================================================
SCANNER_MAX_CONCURRENT=3
# SCAN_OUTPUT_DIR=scan_outputs

# ============================================================
# 服务器配置
# ============================================================
HOST=0.0.0.0
PORT=8000

# ============================================================
# 邮件/推送通知配置 (可选)
# ============================================================
# PUSH_SANDBOX_MODE=0
# PUSH_TIMEOUT_SECONDS=10
# PUSH_SMTP_HOST=smtp.example.com
# PUSH_SMTP_PORT=587
# PUSH_SMTP_USER=your-email@example.com
# PUSH_SMTP_PASSWORD=your-password
# PUSH_SMTP_TLS=1
# PUSH_SMTP_FROM=Aimiguan <noreply@example.com>

# ============================================================
# TTS 语音合成配置 (可选，用于 AI 播报)
# ============================================================
# TTS_PROVIDER=local  # 支持: local, openai, elevenlabs
# TTS_ENDPOINT=
# TTS_BASE_URL=http://localhost:5000
# TTS_MODEL=local-tts-v1
# TTS_TIMEOUT_SECONDS=30
# TTS_API_KEY=
# TTS_SANDBOX_MODE=0

# ============================================================
# STT 语音识别配置 (可选)
# ============================================================
# STT_PROVIDER=local  # 支持: local, openai, whisper
# STT_ENDPOINT=
# STT_BASE_URL=http://localhost:5001
# STT_TIMEOUT_SECONDS=10
# STT_API_KEY=

# ============================================================
# SPA 单包授权配置 (可选)
# ============================================================
# SPA_SECRET=  # 用于单包授权的密钥
# SPA_TOKEN_TTL=300

# ============================================================
# 凭据加密配置 (可选)
# ============================================================
# CREDENTIAL_KEY_V1=          # AES-256 base64url, 留空则自动生成
# CREDENTIAL_KEY_V2=          # 密钥轮换时配置

# ============================================================
# 防火墙集成配置 (可选)
# ============================================================
# FIREWALL_API_URL=http://防火墙API地址
# FIREWALL_SIGN_SECRET=

# ============================================================
# 安全配置
# ============================================================
# IP_WHITELIST=  # 逗号分隔的IP白名单，为空则允许所有
# DECOY_ENABLED=0  # 是否启用蜜罐诱捕功能 (0/1)
# DEFENSE_RUNTIME_WORKFLOW_KEY=  # 防御运行时工作流密钥
# ROLLBACK_CANDIDATE_LIMIT=10  # 回滚候选数量限制