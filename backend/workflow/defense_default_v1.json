{
  "schema_version": "1.0.0",
  "workflow_id": "defense_default",
  "version": 1,
  "name": "Defense Default Workflow v1",
  "description": "HFish 入站事件默认处置流程：评分、审批、动作、审计。",
  "status": "DRAFT",
  "context": {
    "inputs": {
      "event": {
        "source": "hfish",
        "required_fields": [
          "ip",
          "attack_count",
          "threat_label"
        ]
      }
    },
    "outputs": {
      "decision": "MONITOR",
      "action_result": null
    },
    "trace_id": "{{ trace_id }}"
  },
  "runtime": {
    "initial_state": "QUEUED",
    "terminal_states": [
      "SUCCESS",
      "FAILED",
      "MANUAL_REQUIRED",
      "CANCELLED"
    ],
    "state_enum": [
      "QUEUED",
      "RUNNING",
      "RETRYING",
      "SUCCESS",
      "FAILED",
      "MANUAL_REQUIRED",
      "CANCELLED"
    ]
  },
  "nodes": [
    {
      "id": "trigger_hfish",
      "type": "trigger",
      "name": "HFish Event Trigger",
      "config": {
        "source_type": "hfish_alert"
      },
      "timeout": 10,
      "retry_policy": {
        "max_retries": 0,
        "backoff_seconds": 5,
        "backoff_multiplier": 2.0,
        "retry_on": []
      }
    },
    {
      "id": "assess_ai",
      "type": "ai_assess",
      "name": "AI Threat Assessment",
      "config": {
        "service": "ai_engine.assess_threat",
        "score_threshold_block": 80,
        "score_threshold_approval": 60
      },
      "timeout": 30,
      "retry_policy": {
        "max_retries": 1,
        "backoff_seconds": 3,
        "backoff_multiplier": 2.0,
        "retry_on": [
          "TIMEOUT",
          "NETWORK_ERROR"
        ]
      }
    },
    {
      "id": "approval",
      "type": "manual_approval",
      "name": "Operator Approval",
      "config": {
        "approval_required": true,
        "sla_seconds": 300
      },
      "timeout": 600,
      "retry_policy": {
        "max_retries": 0,
        "backoff_seconds": 5,
        "backoff_multiplier": 2.0,
        "retry_on": []
      }
    },
    {
      "id": "block_action",
      "type": "mcp_action",
      "name": "Block Source IP",
      "config": {
        "service": "mcp_client.block_ip",
        "idempotent": true
      },
      "timeout": 20,
      "retry_policy": {
        "max_retries": 3,
        "backoff_seconds": 3,
        "backoff_multiplier": 2.0,
        "retry_on": [
          "TIMEOUT",
          "TEMPORARY_UNAVAILABLE"
        ]
      }
    },
    {
      "id": "audit_log",
      "type": "audit",
      "name": "Write Audit Log",
      "config": {
        "service": "audit_service.log",
        "required_fields": [
          "actor",
          "action",
          "result",
          "trace_id"
        ]
      },
      "timeout": 10,
      "retry_policy": {
        "max_retries": 1,
        "backoff_seconds": 2,
        "backoff_multiplier": 1.5,
        "retry_on": [
          "DB_LOCKED"
        ]
      }
    }
  ],
  "edges": [
    {
      "from": "trigger_hfish",
      "to": "assess_ai",
      "condition": "true",
      "priority": 100
    },
    {
      "from": "assess_ai",
      "to": "approval",
      "condition": "score >= 60",
      "priority": 10
    },
    {
      "from": "assess_ai",
      "to": "audit_log",
      "condition": "score < 60",
      "priority": 20
    },
    {
      "from": "approval",
      "to": "block_action",
      "condition": "approved == true",
      "priority": 10
    },
    {
      "from": "approval",
      "to": "audit_log",
      "condition": "approved == false",
      "priority": 20
    },
    {
      "from": "block_action",
      "to": "audit_log",
      "condition": "true",
      "priority": 100
    }
  ],
  "metadata": {
    "owner": "secops",
    "tags": [
      "defense",
      "default"
    ]
  }
}

