{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aimiguan.local/schema/workflow/dsl.v1.json",
  "title": "Aimiguan Workflow DSL v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_id",
    "version",
    "name",
    "status",
    "context",
    "runtime",
    "nodes",
    "edges"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "VALIDATED",
        "PUBLISHED",
        "ARCHIVED"
      ]
    },
    "context": {
      "$ref": "#/$defs/context"
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_retries",
        "backoff_seconds",
        "backoff_multiplier",
        "retry_on"
      ],
      "properties": {
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "backoff_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "backoff_multiplier": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 5.0
        },
        "retry_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "name",
        "config",
        "timeout",
        "retry_policy"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        },
        "timeout": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "retry_policy": {
          "$ref": "#/$defs/retry_policy"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "condition",
        "priority"
      ],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "to": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "condition": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9999
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inputs",
        "outputs"
      ],
      "properties": {
        "inputs": {
          "type": "object",
          "additionalProperties": true
        },
        "outputs": {
          "type": "object",
          "additionalProperties": true
        },
        "trace_id": {
          "type": "string",
          "maxLength": 128
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_state",
        "terminal_states",
        "state_enum"
      ],
      "properties": {
        "initial_state": {
          "$ref": "#/$defs/run_state"
        },
        "terminal_states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/run_state"
          }
        },
        "state_enum": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/run_state"
          }
        }
      }
    },
    "run_state": {
      "type": "string",
      "enum": [
        "QUEUED",
        "RUNNING",
        "RETRYING",
        "SUCCESS",
        "FAILED",
        "MANUAL_REQUIRED",
        "CANCELLED"
      ]
    }
  }
}

